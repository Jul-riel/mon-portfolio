---

---

<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Julio Riel | Développeur Fullstack</title>

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-slate-950 text-white overflow-x-hidden">

    <!-- Background -->
    <div class="fixed inset-0 -z-10">
        <div class="absolute top-0 left-0 w-96 h-96 bg-cyan-500/20 blur-3xl rounded-full"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-blue-500/20 blur-3xl rounded-full"></div>
    </div>

    <!-- NAVBAR -->
    <header class="fixed top-0 w-full backdrop-blur-md bg-slate-950/60 border-b border-slate-800 z-50">
        <nav class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">

            <h1 class="font-bold text-xl">
                Julio<span class="text-cyan-400">.</span>
            </h1>

            <ul class="hidden md:flex gap-8 text-slate-300">
                <li><a href="#" class="hover:text-cyan-400 transition">Accueil</a></li>
                <li><a href="#projets" class="hover:text-cyan-400 transition">Projets</a></li>
                <li><a href="#" class="hover:text-cyan-400 transition">Compétences</a></li>
                <li><a href="#" class="hover:text-cyan-400 transition">Contact</a></li>
            </ul>

        </nav>
    </header>

    <!-- HERO -->
    <section class="min-h-screen flex items-center">
    <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="grid lg:grid-cols-2 gap-16 items-center">

            <!-- Partie gauche -->
            <div>

                <span class="px-4 py-2 rounded-full bg-cyan-500/10 border border-cyan-500/20 text-cyan-400 text-sm">
                    Étudiant en Informatique • Développeur Web Fullstack
                </span>

                <h1 class="text-5xl md:text-7xl font-black mt-6 leading-tight">
                    Je transforme des idées en
                    <span class="bg-gradient-to-r from-cyan-400 to-blue-500 bg-clip-text text-transparent">
                        applications web
                    </span>
                </h1>

                <h2 class="text-2xl text-slate-300 mt-4">
                    RIEL Maherisoa Julio
                </h2>

                <p class="mt-6 text-slate-400 text-lg max-w-xl leading-relaxed">
                    Je suis étudiant en informatique passionné par le développement
                    web Fullstack. Je développe des applications modernes avec PHP,
                    MySQL, React, Node.js et Astro tout en renforçant mes compétences
                    à travers des projets académiques et personnels.
                </p>

                <div class="flex flex-wrap gap-4 mt-8">

                    <a
                        href="#projets"
                        class="px-8 py-4 rounded-xl bg-cyan-500 hover:bg-cyan-400 transition font-semibold text-slate-950"
                    >
                        Voir mes projets
                    </a>

                    <a
                        href="/cv/CV_RIEL_Maherisoa_Julio.pdf"
                        target="_blank"
                        class="px-8 py-4 rounded-xl border border-slate-700 hover:border-cyan-500 transition"
                    >
                        Télécharger mon CV
                    </a>

                </div>

            </div>

            <!-- Carte profil -->
            <div class="flex justify-center">

                <div class="w-full max-w-md bg-slate-900/70 backdrop-blur-lg border border-slate-800 rounded-3xl p-8">

                    <div class="flex justify-center">
                        <div class="w-32 h-32 rounded-full bg-gradient-to-r from-cyan-400 to-blue-500 flex items-center justify-center text-5xl font-bold">
                            JR
                        </div>
                    </div>

                    <h3 class="text-center text-2xl font-bold mt-6">
                        RIEL Maherisoa Julio
                    </h3>

                    <p class="text-center text-slate-400 mt-2">
                        Étudiant en Informatique
                    </p>

                    <div class="grid grid-cols-3 gap-4 mt-8 text-center">

                        <div>
                            <h4 class="font-bold text-2xl text-cyan-400">
                                3+
                            </h4>
                            <p class="text-slate-500 text-sm">
                                Projets réalisés
                            </p>
                        </div>

                        <div>
                            <h4 class="font-bold text-2xl text-cyan-400">
                                PHP
                            </h4>
                            <p class="text-slate-500 text-sm">
                                MySQL
                            </p>
                        </div>

                        <div>
                            <h4 class="font-bold text-2xl text-cyan-400">
                                React
                            </h4>
                            <p class="text-slate-500 text-sm">
                                Node.js
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
</section>

    <!-- PROJETS -->
    <section
        id="projets"
        class="max-w-7xl mx-auto px-6 py-24"
    >

        <h2
            class="text-center text-4xl font-bold mb-4"
        >
            Mes Projets
        </h2>

        <p
            class="text-center text-slate-400 mb-16"
        >
            Quelques réalisations mettant en pratique mes compétences.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

            <!-- Projet 1 -->
            <div
                class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-cyan-500 transition"
            >
                <h3 class="text-xl font-bold mb-3">
                    Gestion de Pension
                </h3>

                <p class="text-slate-400 mb-5">
                    Application web de gestion des retraités,
                    paiements et génération de reçus PDF.
                </p>

                <div class="flex flex-wrap gap-2">

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        PHP
                    </span>

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        MySQL
                    </span>

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        MVC
                    </span>

                </div>
            </div>

            <!-- Projet 2 -->
            <div
                class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-cyan-500 transition"
            >
                <h3 class="text-xl font-bold mb-3">
                    E-Mairie
                </h3>

                <p class="text-slate-400 mb-5">
                    Plateforme numérique destinée à moderniser
                    les services administratifs communaux.
                </p>

                <div class="flex flex-wrap gap-2">

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        React
                    </span>

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        Node.js
                    </span>

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        MySQL
                    </span>

                </div>
            </div>

            <!-- Projet 3 -->
            <div
                class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-cyan-500 transition"
            >
                <h3 class="text-xl font-bold mb-3">
                    Portfolio Astro
                </h3>

                <p class="text-slate-400 mb-5">
                    Portfolio personnel développé avec Astro
                    et Tailwind CSS.
                </p>

                <div class="flex flex-wrap gap-2">

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        Astro
                    </span>

                    <span class="bg-slate-800 px-3 py-1 rounded">
                        Tailwind
                    </span>

                </div>
            </div>

        </div>

    </section>

</body>
</html>